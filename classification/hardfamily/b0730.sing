  else { LIVEV[i] = 1; nlive++; "BRANCH", i, "LIVE ngens", size(BR[i]); }
}
"NLIVE", nlive;
ring rf = 0, (q0, q1, q2, q3, q4, q5, q6, q7, q8, q9, q10, q11, q12, q13, q14, q15, q16, q17, q18, q19, q20, q21, q22, x, y, z, X, Y, Z, t, s), dp;
ideal KEf = imap(rq, KE); poly det0f = imap(rq, det0);
ideal COLL = -X^6*q8 - X^5*q7 - X^4*q6 - X^3*q5 - X^2*q4 - X*Y^4*Z*q3 - X*q2 - Y^4*Z*q1 + q1*y^4*z + q2*x + q3*x*y^4*z + q4*x^2 + q5*x^3 + q6*x^4 + q7*x^5 + q8*x^6,-X^5*Y*q15 - X^4*Y*q14 - X^3*Y*q13 - X^2*Y*q12 - X*Y*q11 - Y^5*Z*q10 - Y*q9 + q10*y^5*z + q11*x*y + q12*x^2*y + q13*x^3*y + q14*x^4*y + q15*x^5*y + q9*y,-X^5*Z*q22 - X^4*Z*q21 - X^3*Z*q20 - X^2*Z*q19 - X*Z*q18 - Y^4*Z^2*q17 - Z*q16 + q16*z + q17*y^4*z^2 + q18*x*z + q19*x^2*z + q20*x^3*z + q21*x^4*z + q22*x^5*z;
list BRf = imap(rq, BR);
ideal diffs = x-X, y-Y, z-Z;
for (i = 1; i <= size(BRf); i++) {
  if (LIVEV[i] == 1) {
    for (kk = 1; kk <= 3; kk++) {
      ideal I = KEf, BRf[i], COLL, t*diffs[kk]-1, s*det0f-1;
      ideal G = groebner(I);
      if (reduce(1, G) != 0) { bad = 1; "NONUNIT branch", i, "k", kk; }
      else { "UNIT branch", i, "k", kk; }
      kill I; kill G;
    }
  }
}
if (bad == 0) { "VERDICT-FACSTD system 730: EMPTY"; }
else { "VERDICT-FACSTD system 730: NONUNIT BRANCH FOUND -- INVESTIGATE"; }
exit;
