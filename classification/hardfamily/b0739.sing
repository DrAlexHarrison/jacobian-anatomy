poly det0 = q12*q21*q3;
list BR = facstd(KE);
"NBRANCH", size(BR);
int i; int kk; int bad = 0; int nlive = 0;
intvec LIVEV; LIVEV[size(BR)] = 0;
for (i = 1; i <= size(BR); i++) {
  if (reduce(det0, std(BR[i])) == 0) { LIVEV[i] = 0; "BRANCH", i, "DEAD (det0 in ideal)"; }
  else { LIVEV[i] = 1; nlive++; "BRANCH", i, "LIVE ngens", size(BR[i]); }
}
"NLIVE", nlive;
ring rf = 0, (q0, q1, q2, q3, q4, q5, q6, q7, q8, q9, q10, q11, q12, q13, q14, q15, q16, q17, q18, q19, q20, q21, q22, q23, q24, q25, q26, q27, q28, q29, x, y, z, X, Y, Z, t, s), dp;
ideal KEf = imap(rq, KE); poly det0f = imap(rq, det0);
ideal COLL = -X^6*q11 - X^5*q10 - X^4*q9 - X^3*Y*Z^2*q8 - X^3*q7 - X^2*Y*Z^2*q6 - X^2*q5 - X*Y*Z^2*q4 - X*q3 - Y^2*Z^4*q2 - Y*Z^2*q1 + q1*y*z^2 + q10*x^5 + q11*x^6 + q2*y^2*z^4 + q3*x + q4*x*y*z^2 + q5*x^2 + q6*x^2*y*z^2 + q7*x^3 + q8*x^3*y*z^2 + q9*x^4,-X^5*Y*q20 - X^4*Y*q19 - X^3*Y*q18 - X^2*Y^2*Z^2*q17 - X^2*Y*q16 - X*Y^2*Z^2*q15 - X*Y*q14 - Y^2*Z^2*q13 - Y*q12 + q12*y + q13*y^2*z^2 + q14*x*y + q15*x*y^2*z^2 + q16*x^2*y + q17*x^2*y^2*z^2 + q18*x^3*y + q19*x^4*y + q20*x^5*y,-X^5*Z*q29 - X^4*Z*q28 - X^3*Z*q27 - X^2*Y*Z^3*q26 - X^2*Z*q25 - X*Y*Z^3*q24 - X*Z*q23 - Y*Z^3*q22 - Z*q21 + q21*z + q22*y*z^3 + q23*x*z + q24*x*y*z^3 + q25*x^2*z + q26*x^2*y*z^3 + q27*x^3*z + q28*x^4*z + q29*x^5*z;
list BRf = imap(rq, BR);
ideal diffs = x-X, y-Y, z-Z;
for (i = 1; i <= size(BRf); i++) {
  if (LIVEV[i] == 1) {
    for (kk = 1; kk <= 3; kk++) {
      ideal I = KEf, BRf[i], COLL, t*diffs[kk]-1, s*det0f-1;
      ideal G = groebner(I);
      if (reduce(1, G) != 0) { bad = 1; "NONUNIT branch", i, "k", kk; }
      else { "UNIT branch", i, "k", kk; }
      kill I; kill G;
    }
  }
}
if (bad == 0) { "VERDICT-FACSTD system 739: EMPTY"; }
else { "VERDICT-FACSTD system 739: NONUNIT BRANCH FOUND -- INVESTIGATE"; }
exit;
