q21 - q11*q20*q3 + 3*q12*q19*q3 + q13*q18*q3 + 5*q13*q19*q2,-6*q1*q10*q22 - 4*q1*q12*q20 - 2*q1*q14*q18 + 2*q10*q18*q5 + 8*q10*q19*q4 + 4*q10*q2*q21 - 2*q10*q20*q3 + 4*q11*q18*q4 + 2*q11*q2*q20 + 4*q12*q19*q2 + 2*q13*q18*q2,2*q10*q18*q4 + q10*q2*q20 + q12*q18*q2,-3*q1*q11*q21 - q1*q13*q19 + 5*q11*q19*q3,-3*q1*q10*q21 - 3*q1*q11*q20 - q1*q12*q19 - q1*q13*q18 + 4*q10*q19*q3 + 2*q11*q18*q3 + 5*q11*q19*q2,-3*q1*q10*q20 - q1*q12*q18 + q10*q18*q3 + 4*q10*q19*q2 + 2*q11*q18*q2;
poly det0 = q10*q18*q2;
list BR = facstd(KE);
"NBRANCH", size(BR);
int i; int kk; int bad = 0; int nlive = 0;
intvec LIVEV; LIVEV[size(BR)] = 0;
for (i = 1; i <= size(BR); i++) {
  if (reduce(det0, std(BR[i])) == 0) { LIVEV[i] = 0; "BRANCH", i, "DEAD (det0 in ideal)"; }
  else { LIVEV[i] = 1; nlive++; "BRANCH", i, "LIVE ngens", size(BR[i]); }
}
"NLIVE", nlive;
ring rf = 0, (q0, q1, q2, q3, q4, q5, q6, q7, q8, q9, q10, q11, q12, q13, q14, q15, q16, q17, q18, q19, q20, q21, q22, q23, q24, q25, x, y, z, X, Y, Z, t, s), dp;
ideal KEf = imap(rq, KE); poly det0f = imap(rq, det0);
ideal COLL = -X^6*q9 - X^5*q8 - X^4*q7 - X^3*q6 - X^2*Y*Z^3*q5 - X^2*q4 - X*Y*Z^3*q3 - X*q2 - Y*Z^3*q1 + q1*y*z^3 + q2*x + q3*x*y*z^3 + q4*x^2 + q5*x^2*y*z^3 + q6*x^3 + q7*x^4 + q8*x^5 + q9*x^6,-X^5*Y*q17 - X^4*Y*q16 - X^3*Y*q15 - X^2*Y*q14 - X*Y^2*Z^3*q13 - X*Y*q12 - Y^2*Z^3*q11 - Y*q10 + q10*y + q11*y^2*z^3 + q12*x*y + q13*x*y^2*z^3 + q14*x^2*y + q15*x^3*y + q16*x^4*y + q17*x^5*y,-X^5*Z*q25 - X^4*Z*q24 - X^3*Z*q23 - X^2*Z*q22 - X*Y*Z^4*q21 - X*Z*q20 - Y*Z^4*q19 - Z*q18 + q18*z + q19*y*z^4 + q20*x*z + q21*x*y*z^4 + q22*x^2*z + q23*x^3*z + q24*x^4*z + q25*x^5*z;
list BRf = imap(rq, BR);
ideal diffs = x-X, y-Y, z-Z;
for (i = 1; i <= size(BRf); i++) {
  if (LIVEV[i] == 1) {
    for (kk = 1; kk <= 3; kk++) {
      ideal I = KEf, BRf[i], COLL, t*diffs[kk]-1, s*det0f-1;
      ideal G = groebner(I);
      if (reduce(1, G) != 0) { bad = 1; "NONUNIT branch", i, "k", kk; }
      else { "UNIT branch", i, "k", kk; }
      kill I; kill G;
    }
  }
}
if (bad == 0) { "VERDICT-FACSTD system 737: EMPTY"; }
else { "VERDICT-FACSTD system 737: NONUNIT BRANCH FOUND -- INVESTIGATE"; }
exit;
