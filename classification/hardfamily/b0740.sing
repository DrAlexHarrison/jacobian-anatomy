ideal COLL = -X^6*q15 - X^5*q14 - X^4*Y*Z*q13 - X^4*q12 - X^3*Y*Z*q11 - X^3*q10 - X^2*Y^2*Z^2*q9 - X^2*Y*Z*q8 - X^2*q7 - X*Y^2*Z^2*q6 - X*Y*Z*q5 - X*q4 - Y^3*Z^3*q3 - Y^2*Z^2*q2 - Y*Z*q1 + q1*y*z + q10*x^3 + q11*x^3*y*z + q12*x^4 + q13*x^4*y*z + q14*x^5 + q15*x^6 + q2*y^2*z^2 + q3*y^3*z^3 + q4*x + q5*x*y*z + q6*x*y^2*z^2 + q7*x^2 + q8*x^2*y*z + q9*x^2*y^2*z^2,-X^5*Y*q27 - X^4*Y*q26 - X^3*Y^2*Z*q25 - X^3*Y*q24 - X^2*Y^2*Z*q23 - X^2*Y*q22 - X*Y^3*Z^2*q21 - X*Y^2*Z*q20 - X*Y*q19 - Y^3*Z^2*q18 - Y^2*Z*q17 - Y*q16 + q16*y + q17*y^2*z + q18*y^3*z^2 + q19*x*y + q20*x*y^2*z + q21*x*y^3*z^2 + q22*x^2*y + q23*x^2*y^2*z + q24*x^3*y + q25*x^3*y^2*z + q26*x^4*y + q27*x^5*y,-X^5*Z*q39 - X^4*Z*q38 - X^3*Y*Z^2*q37 - X^3*Z*q36 - X^2*Y*Z^2*q35 - X^2*Z*q34 - X*Y^2*Z^3*q33 - X*Y*Z^2*q32 - X*Z*q31 - Y^2*Z^3*q30 - Y*Z^2*q29 - Z*q28 + q28*z + q29*y*z^2 + q30*y^2*z^3 + q31*x*z + q32*x*y*z^2 + q33*x*y^2*z^3 + q34*x^2*z + q35*x^2*y*z^2 + q36*x^3*z + q37*x^3*y*z^2 + q38*x^4*z + q39*x^5*z;
list BRf = imap(rq, BR);
ideal diffs = x-X, y-Y, z-Z;
for (i = 1; i <= size(BRf); i++) {
