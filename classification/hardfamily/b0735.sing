q2 + q13*q15*q5 + 4*q13*q16*q4 + 7*q13*q17*q3 - 7*q13*q18*q2 - 4*q14*q15*q2 + 6*q17*q7*q9 - 6*q2*q22*q9,-4*q0*q10*q22 - 6*q0*q11*q21 - 2*q0*q13*q19 + 2*q0*q14*q16 - 6*q1*q10*q21 - 3*q1*q12*q19 - 5*q1*q13*q18 - 2*q1*q14*q15 - 4*q1*q22*q9 + 4*q10*q15*q7 + 6*q10*q16*q6 - 2*q10*q18*q5 + 2*q10*q20*q3 + 6*q11*q15*q6 - q11*q18*q4 + q11*q19*q3 + 3*q12*q16*q4 + 6*q12*q17*q3 - 6*q12*q18*q2 + 2*q13*q15*q4 + 5*q13*q16*q3 + 4*q16*q7*q9 + 6*q17*q6*q9 - q19*q5*q9 - 6*q2*q21*q9 + q20*q4*q9,-4*q0*q10*q21 - q0*q12*q19 - 3*q0*q13*q18 - 2*q0*q22*q9 - 4*q1*q12*q18 - 4*q1*q21*q9 + 4*q10*q15*q6 - q10*q18*q4 + q10*q19*q3 + q12*q15*q4 + 4*q12*q16*q3 + 3*q13*q15*q3 + 2*q15*q7*q9 + 4*q16*q6*q9 - 2*q18*q5*q9 + 2*q20*q3*q9,-2*q0*q12*q18 - 2*q0*q21*q9 + 2*q12*q15*q3 + 2*q15*q6*q9 - q18*q4*q9 + q19*q3*q9,5*q11*q17*q5 - 5*q11*q2*q20,-4*q1*q11*q20 + q1*q13*q17 + 4*q10*q17*q5 - 4*q10*q2*q20 + 4*q11*q16*q5 + 5*q11*q17*q4 - 5*q11*q19*q2 - q13*q16*q2,-3*q0*q11*q20 + 2*q0*q13*q17 - 3*q1*q10*q20 - 4*q1*q11*q19 + q1*q12*q17 + 3*q10*q16*q5 + 4*q10*q17*q4 - 4*q10*q19*q2 + 3*q11*q15*q5 + 4*q11*q16*q4 + 5*q11*q17*q3 - 5*q11*q18*q2 - q12*q16*q2 - 2*q13*q15*q2 + 3*q17*q5*q9 - 3*q2*q20*q9,-2*q0*q10*q20 - 3*q0*q11*q19 + 2*q0*q12*q17 + q0*q13*q16 - 3*q1*q10*q19 - 4*q1*q11*q18 - q1*q13*q15 - 2*q1*q20*q9 + 2*q10*q15*q5 + 3*q10*q16*q4 + 4*q10*q17*q3 - 4*q10*q18*q2 + 3*q11*q15*q4 + 4*q11*q16*q3 - 2*q12*q15*q2 + 2*q16*q5*q9 + 3*q17*q4*q9 - 3*q19*q2*q9,-2*q0*q10*q19 - 3*q0*q11*q18 + q0*q12*q16 - q0*q20*q9 - 3*q1*q10*q18 - q1*q12*q15 - 2*q1*q19*q9 + 2*q10*q15*q4 + 3*q10*q16*q3 + 3*q11*q15*q3 + q15*q5*q9 + 2*q16*q4*q9 + 3*q17*q3*q9 - 3*q18*q2*q9,-2*q0*q10*q18 - q0*q19*q9 - 2*q1*q18*q9 + 2*q10*q15*q3 + q15*q4*q9 + 2*q16*q3*q9;
poly det0 = -q0*q18*q9 + q15*q3*q9;
list BR = facstd(KE);
"NBRANCH", size(BR);
int i; int kk; int bad = 0; int nlive = 0;
intvec LIVEV; LIVEV[size(BR)] = 0;
