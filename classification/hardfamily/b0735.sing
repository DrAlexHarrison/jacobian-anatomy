  else { LIVEV[i] = 1; nlive++; "BRANCH", i, "LIVE ngens", size(BR[i]); }
}
"NLIVE", nlive;
ring rf = 0, (q0, q1, q2, q3, q4, q5, q6, q7, q8, q9, q10, q11, q12, q13, q14, q15, q16, q17, q18, q19, q20, q21, q22, q23, x, y, z, X, Y, Z, t, s), dp;
ideal KEf = imap(rq, KE); poly det0f = imap(rq, det0);
ideal COLL = -X^3*Y^2*q8 - X^2*Y^2*Z*q7 - X^2*Y*q6 - X*Y^2*Z^2*q5 - X*Y*Z*q4 - X*q3 - Y^2*Z^3*q2 - Y*Z^2*q1 - Z*q0 + q0*z + q1*y*z^2 + q2*y^2*z^3 + q3*x + q4*x*y*z + q5*x*y^2*z^2 + q6*x^2*y + q7*x^2*y^2*z + q8*x^3*y^2,-X^2*Y^3*q14 - X*Y^3*Z*q13 - X*Y^2*q12 - Y^3*Z^2*q11 - Y^2*Z*q10 - Y*q9 + q10*y^2*z + q11*y^3*z^2 + q12*x*y^2 + q13*x*y^3*z + q14*x^2*y^3 + q9*y,-X^3*Y^2*q23 - X^2*Y^2*Z*q22 - X^2*Y*q21 - X*Y^2*Z^2*q20 - X*Y*Z*q19 - X*q18 - Y^2*Z^3*q17 - Y*Z^2*q16 - Z*q15 + q15*z + q16*y*z^2 + q17*y^2*z^3 + q18*x + q19*x*y*z + q20*x*y^2*z^2 + q21*x^2*y + q22*x^2*y^2*z + q23*x^3*y^2;
list BRf = imap(rq, BR);
ideal diffs = x-X, y-Y, z-Z;
for (i = 1; i <= size(BRf); i++) {
  if (LIVEV[i] == 1) {
    for (kk = 1; kk <= 3; kk++) {
      ideal I = KEf, BRf[i], COLL, t*diffs[kk]-1, s*det0f-1;
      ideal G = groebner(I);
      if (reduce(1, G) != 0) { bad = 1; "NONUNIT branch", i, "k", kk; }
      else { "UNIT branch", i, "k", kk; }
      kill I; kill G;
    }
  }
}
if (bad == 0) { "VERDICT-FACSTD system 735: EMPTY"; }
else { "VERDICT-FACSTD system 735: NONUNIT BRANCH FOUND -- INVESTIGATE"; }
exit;
