// zero-weight rigidity certificates, system 725: w=[0, 5, -1] (b=5, c=1), u = y^1 z^5
ring rq = 0, (q0, q1, q2, q3, q4, q5, q6, q7, q8, q9, q10, q11, q12, q13, q14, q15, q16, q17, q18, q19, s, t), dp;
