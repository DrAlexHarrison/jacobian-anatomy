else { "UNIT q15 DECISIVE"; }
kill I15; kill G15;
ideal I16 = KE, s*det0-1, t*q16-1;
ideal G16 = groebner(I16);
if (reduce(1, G16) != 0) { bad = 1; "NONUNIT-DECISIVE q16 comp 2 alpha (2, 0, 1)"; }
else { "UNIT q16 DECISIVE"; }
