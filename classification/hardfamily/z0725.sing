else { "UNIT q19 DECISIVE"; }
kill I19; kill G19;
if (bad == 0) { "VERDICT-ZWRIGID system 725: RIGID (Q,R constant forced) => EMPTY by hand endgame"; }
else { "VERDICT-ZWRIGID system 725: NOT RIGID -- check DECISIVE flags; DECISIVE nonunit = NONEMPTY SIREN"; }
exit;
