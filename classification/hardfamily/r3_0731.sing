poly det0 = q16*q2*q9;
list CMP = facstd(KE);
"R3-NCOMP", size(CMP);
int i; int kk; int nlive = 0; int bad = 0;
intvec LIVEV; LIVEV[size(CMP)] = 0;
for (i = 1; i <= size(CMP); i++) {
  if (reduce(det0, std(CMP[i])) == 0) { "R3-COMP", i, "DEAD"; }
  else { LIVEV[i] = 1; nlive++; "R3-COMP", i, "LIVE ngens", size(CMP[i]); }
}
"R3-NLIVE", nlive;
ring rf = 0, (s, t, Z, Y, X, z, y, x, q22, q21, q20, q19, q18, q17, q16, q15, q14, q13, q12, q11, q10, q9, q8, q7, q6, q5, q4, q3, q2, q1, q0), dp;
ideal KEf = imap(rq, KE); poly det0f = imap(rq, det0);
ideal COLL = -X^6*q8 - X^5*q7 - X^4*q6 - X^3*q5 - X^2*q4 - X*Y^3*Z^2*q3 - X*q2 - Y^3*Z^2*q1 + q1*y^3*z^2 + q2*x + q3*x*y^3*z^2 + q4*x^2 + q5*x^3 + q6*x^4 + q7*x^5 + q8*x^6,-X^5*Y*q15 - X^4*Y*q14 - X^3*Y*q13 - X^2*Y*q12 - X*Y*q11 - Y^4*Z^2*q10 - Y*q9 + q10*y^4*z^2 + q11*x*y + q12*x^2*y + q13*x^3*y + q14*x^4*y + q15*x^5*y + q9*y,-X^5*Z*q22 - X^4*Z*q21 - X^3*Z*q20 - X^2*Z*q19 - X*Z*q18 - Y^3*Z^3*q17 - Z*q16 + q16*z + q17*y^3*z^3 + q18*x*z + q19*x^2*z + q20*x^3*z + q21*x^4*z + q22*x^5*z;
list CMPf = imap(rq, CMP);
ideal diffs = x-X, y-Y, z-Z;
for (i = 1; i <= size(CMPf); i++) {
  if (LIVEV[i] == 1) {
    for (kk = 1; kk <= 3; kk++) {
      ideal I = KEf, CMPf[i], COLL, t*diffs[kk]-1, s*det0f-1;
      ideal G = groebner(I);
      if (reduce(1, G) != 0) { bad = 1; "R3-NONUNIT comp", i, "k", kk; }
      else { "R3-UNIT comp", i, "k", kk; }
      kill I; kill G;
    }
  }
}
if (bad == 0) { "R3-CERT system 731: ALL-UNIT"; } else { "R3-CERT system 731: NONUNIT FOUND -- INVESTIGATE"; }
setring rq;
ideal J = CMP[1];
for (i = 2; i <= size(CMP); i++) { J = intersect(J, CMP[i]); }
"R3-COVER-NGENS", size(J);
ring rr = 0, (q22, q21, q20, q19, q18, q17, q16, q15, q14, q13, q12, q11, q10, q9, q8, q7, q6, q5, q4, q3, q2, q1, q0, tt), dp;
ideal KEr = imap(rq, KE); ideal Jr = imap(rq, J);
int cbad = 0;
for (i = 1; i <= size(Jr); i++) {
  ideal CI = KEr, tt*Jr[i]-1;
  ideal CG = groebner(CI);
  if (reduce(1, CG) != 0) { cbad = 1; "R3-COVER-GEN", i, "FAIL -- NOT in radical(KE)"; }
  else { "R3-COVER-GEN", i, "IN-RADICAL"; }
  kill CI; kill CG;
}
if (cbad == 0) { "R3-COVERING system 731: ALL generators of intersection in radical(KE) -- covering SOUND"; }
"R3-DONE system 731";
exit;
