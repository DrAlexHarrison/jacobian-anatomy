// system 270: w=[1, -2, 11] sizes=[3, 2, 2] maxdeg=6
ring r = 0, (q0, q1, q2, q3, q4, q5, q6, x, y, z, X, Y, Z, t, s), dp;
ideal KE = 4*q2*q4*q6,2*q1*q4*q6 + 3*q2*q3*q6 + 4*q2*q4*q5,-12*q0*q4*q6,q1*q3*q6 + 2*q1*q4*q5 + 3*q2*q3*q5,-2*q0*q3*q6 - 10*q0*q4*q5;
poly det0 = q1*q3*q5;
ideal COLL = -X^3*Y*q2 - X*q1 - Y^5*Z*q0 + q0*y^5*z + q1*x + q2*x^3*y,-X^2*Y^2*q4 - Y*q3 + q3*y + q4*x^2*y^2,-X^2*Y*Z*q6 - Z*q5 + q5*z + q6*x^2*y*z;
int allunit = 1;
ideal I0 = KE, COLL, t*(x-X)-1, s*det0-1;
ideal G0 = groebner(I0);
if (reduce(1, G0) != 0) { allunit = 0; "NONUNIT k=0 system 270"; }
ideal I1 = KE, COLL, t*(y-Y)-1, s*det0-1;
ideal G1 = groebner(I1);
if (reduce(1, G1) != 0) { allunit = 0; "NONUNIT k=1 system 270"; }
ideal I2 = KE, COLL, t*(z-Z)-1, s*det0-1;
ideal G2 = groebner(I2);
if (reduce(1, G2) != 0) { allunit = 0; "NONUNIT k=2 system 270"; }
if (allunit == 1) { "VERDICT system 270: EMPTY (no equivariant Keller counterexample in this family)"; }
else { "VERDICT system 270: NONEMPTY -- WITNESS HUNT REQUIRED"; }
exit;
